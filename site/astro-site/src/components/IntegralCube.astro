---
/**
 * Interactive wireframe integral cube showing the radiometric measurement
 * framework. Each corner is labeled with its binary code, quantity name,
 * and SI unit. Drag to rotate.
 */
---

<div class="integral-cube-container">
  <canvas id="integral-cube" width="720" height="520"></canvas>
  <p class="cube-caption">Drag to rotate. Each corner shows the binary integration code (A&Omega;&lambda;), the radiometric quantity, and its unit.</p>
</div>

<script>
  function initCube() {
    const canvas = document.getElementById('integral-cube') as HTMLCanvasElement;
    if (!canvas) return;
    const ctx = canvas.getContext('2d')!;

    // Design tokens matching the site
    const ACCENT = '#2337ff';
    const GRAY = 'rgb(96, 115, 159)';
    const GRAY_LIGHT = 'rgb(229, 233, 240)';
    const GRAY_DARK = 'rgb(34, 41, 57)';
    const BG = '#ffffff';
    const FONT_HEADING = "'Michroma', 'Arial Black', Impact, sans-serif";
    const FONT_BODY = "'Lora', 'Times New Roman', Georgia, serif";

    // Corner data: [code, name, unit]
    const corners: [string, string, string][] = [
      ['000', 'Spectral Radiance',          'W/(sr·m²·nm)'],
      ['001', 'Radiance',                   'W/(sr·m²)'],
      ['010', 'Spectral Irradiance',        'W/(m²·nm)'],
      ['011', 'Irradiance',                 'W/m²'],
      ['100', 'Spectral Radiant Intensity', 'W/(sr·nm)'],
      ['101', 'Radiant Intensity',          'W/sr'],
      ['110', 'Spectral Radiant Flux',      'W/nm'],
      ['111', 'Radiant Flux',               'W'],
    ];

    // Cube vertices in [-1,1]^3 mapped by binary code
    // bit2=A (x), bit1=Ω (y), bit0=λ (z)
    const verts = corners.map(([code]) => {
      const a = code[0] === '1' ? 1 : -1;
      const o = code[1] === '1' ? 1 : -1;
      const l = code[2] === '1' ? 1 : -1;
      return [a, o, l] as [number, number, number];
    });

    // Edges of a cube: connect vertices that differ by exactly one bit
    const edges: [number, number][] = [];
    for (let i = 0; i < 8; i++) {
      for (let j = i + 1; j < 8; j++) {
        const xor = parseInt(corners[i][0], 2) ^ parseInt(corners[j][0], 2);
        if (xor === 1 || xor === 2 || xor === 4) {
          edges.push([i, j]);
        }
      }
    }

    // Axis labels positioned just beyond the cube
    const axisLabels = [
      { from: [-1, -1, -1], to: [1.35, -1, -1], label: 'Area (A)', color: ACCENT },
      { from: [-1, -1, -1], to: [-1, 1.35, -1], label: 'Solid Angle (Ω)', color: ACCENT },
      { from: [-1, -1, -1], to: [-1, -1, 1.35], label: 'Wavelength (λ)', color: ACCENT },
    ];

    // Rotation state
    let rotX = -0.45;
    let rotY = 0.65;
    let dragging = false;
    let lastX = 0;
    let lastY = 0;

    // Label alignment hints per corner to avoid overlap
    const labelAlign: [CanvasTextAlign, number, number][] = [
      ['right', -10, 6],    // 000
      ['right', -10, -6],   // 001
      ['right', -10, 6],    // 010
      ['right', -10, -6],   // 011
      ['left', 10, 6],      // 100
      ['left', 10, -6],     // 101
      ['left', 10, 6],      // 110
      ['left', 10, -6],     // 111
    ];

    function rotateY3(p: number[], a: number): number[] {
      const c = Math.cos(a), s = Math.sin(a);
      return [p[0]*c + p[2]*s, p[1], -p[0]*s + p[2]*c];
    }
    function rotateX3(p: number[], a: number): number[] {
      const c = Math.cos(a), s = Math.sin(a);
      return [p[0], p[1]*c - p[2]*s, p[1]*s + p[2]*c];
    }

    function project(p: number[]): [number, number, number] {
      let r = rotateY3(p, rotY);
      r = rotateX3(r, rotX);
      const d = 4.5;
      const scale = d / (d - r[2]);
      const cx = canvas.width / 2;
      const cy = canvas.height / 2;
      const s = Math.min(canvas.width, canvas.height) * 0.22;
      return [cx + r[0] * s * scale, cy + r[1] * s * scale, r[2]];
    }

    function draw() {
      ctx.clearRect(0, 0, canvas.width, canvas.height);

      // Project all vertices
      const projected = verts.map(v => project(v));

      // Draw edges
      ctx.lineWidth = 1;
      for (const [i, j] of edges) {
        const [x1, y1, z1] = projected[i];
        const [x2, y2, z2] = projected[j];
        const avgZ = (z1 + z2) / 2;
        const opacity = 0.25 + 0.35 * ((avgZ + 1.5) / 3);
        ctx.strokeStyle = `rgba(96, 115, 159, ${opacity})`;
        ctx.beginPath();
        ctx.moveTo(x1, y1);
        ctx.lineTo(x2, y2);
        ctx.stroke();
      }

      // Draw axis arrows from 000 corner
      for (const axis of axisLabels) {
        const [fx, fy] = project(axis.from);
        const [tx, ty] = project(axis.to as number[]);
        ctx.strokeStyle = ACCENT;
        ctx.lineWidth = 1.5;
        ctx.beginPath();
        ctx.moveTo(fx, fy);
        ctx.lineTo(tx, ty);
        ctx.stroke();

        // Arrowhead
        const angle = Math.atan2(ty - fy, tx - fx);
        const headLen = 8;
        ctx.beginPath();
        ctx.moveTo(tx, ty);
        ctx.lineTo(tx - headLen * Math.cos(angle - 0.4), ty - headLen * Math.sin(angle - 0.4));
        ctx.moveTo(tx, ty);
        ctx.lineTo(tx - headLen * Math.cos(angle + 0.4), ty - headLen * Math.sin(angle + 0.4));
        ctx.stroke();

        // Axis label
        ctx.font = `11px ${FONT_HEADING}`;
        ctx.fillStyle = ACCENT;
        ctx.textAlign = 'center';
        ctx.textBaseline = 'middle';
        const lx = tx + 18 * Math.cos(angle);
        const ly = ty + 18 * Math.sin(angle);
        ctx.fillText(axis.label, lx, ly);
      }

      // Sort corners by z-depth for painter's algorithm on labels
      const order = projected.map((p, i) => ({ i, z: p[2] }));
      order.sort((a, b) => a.z - b.z);

      for (const { i } of order) {
        const [x, y, z] = projected[i];
        const [code, name, unit] = corners[i];
        const [align, ox, oy] = labelAlign[i];

        // Dot at corner
        const dotR = 3.5;
        const isOrigin = code === '000';
        const isFlux = code === '111';
        ctx.beginPath();
        ctx.arc(x, y, dotR, 0, Math.PI * 2);
        ctx.fillStyle = isOrigin || isFlux ? ACCENT : GRAY_DARK;
        ctx.fill();

        // Label background for readability
        ctx.font = `bold 11px ${FONT_HEADING}`;
        const codeWidth = ctx.measureText(code).width;
        ctx.font = `12px ${FONT_BODY}`;
        const nameWidth = ctx.measureText(name).width;
        ctx.font = `10px ${FONT_BODY}`;
        const unitWidth = ctx.measureText(unit).width;
        const maxW = Math.max(codeWidth, nameWidth, unitWidth);

        const bgX = align === 'left' ? x + ox - 4 : x + ox - maxW - 4;
        const bgY = y + oy - 13;
        ctx.fillStyle = 'rgba(255,255,255,0.88)';
        ctx.fillRect(bgX, bgY, maxW + 8, 42);

        // Code
        ctx.textAlign = align;
        ctx.textBaseline = 'top';
        ctx.font = `bold 11px ${FONT_HEADING}`;
        ctx.fillStyle = isOrigin || isFlux ? ACCENT : GRAY_DARK;
        ctx.fillText(code, x + ox, y + oy - 11);

        // Name
        ctx.font = `12px ${FONT_BODY}`;
        ctx.fillStyle = GRAY_DARK;
        ctx.fillText(name, x + ox, y + oy + 1);

        // Unit
        ctx.font = `10px ${FONT_BODY}`;
        ctx.fillStyle = GRAY;
        ctx.fillText(unit, x + ox, y + oy + 17);
      }
    }

    // Interaction
    canvas.addEventListener('mousedown', (e) => {
      dragging = true;
      lastX = e.clientX;
      lastY = e.clientY;
      canvas.style.cursor = 'grabbing';
    });
    window.addEventListener('mousemove', (e) => {
      if (!dragging) return;
      const dx = e.clientX - lastX;
      const dy = e.clientY - lastY;
      rotY += dx * 0.007;
      rotX += dy * 0.007;
      lastX = e.clientX;
      lastY = e.clientY;
      draw();
    });
    window.addEventListener('mouseup', () => {
      dragging = false;
      canvas.style.cursor = 'grab';
    });

    // Touch support
    canvas.addEventListener('touchstart', (e) => {
      if (e.touches.length === 1) {
        dragging = true;
        lastX = e.touches[0].clientX;
        lastY = e.touches[0].clientY;
        e.preventDefault();
      }
    }, { passive: false });
    canvas.addEventListener('touchmove', (e) => {
      if (!dragging || e.touches.length !== 1) return;
      const dx = e.touches[0].clientX - lastX;
      const dy = e.touches[0].clientY - lastY;
      rotY += dx * 0.007;
      rotX += dy * 0.007;
      lastX = e.touches[0].clientX;
      lastY = e.touches[0].clientY;
      draw();
      e.preventDefault();
    }, { passive: false });
    canvas.addEventListener('touchend', () => { dragging = false; });

    canvas.style.cursor = 'grab';
    draw();
  }

  document.addEventListener('astro:page-load', initCube);
  initCube();
</script>

<style>
  .integral-cube-container {
    margin: 2em 0;
    text-align: center;
  }
  #integral-cube {
    max-width: 100%;
    height: auto;
    border: 1px solid rgb(var(--gray-light));
    border-radius: 8px;
  }
  .cube-caption {
    font-size: 0.8em;
    color: rgb(var(--gray));
    margin-top: 0.5em;
    font-style: italic;
  }
</style>
