---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import TableOfContents from '../components/TableOfContents.astro';
import { Image } from 'astro:assets';

interface Heading {
	depth: number;
	slug: string;
	text: string;
}

type Props = CollectionEntry<'blog'>['data'] & {
	headings?: Heading[];
};

const { title, description, author, pubDate, updatedDate, heroImage, headings = [] } = Astro.props;
---

<html lang="en">
  <BaseHead
    title={title}
    description={description}
    image={heroImage}
    pubDate={pubDate}
    author={author}
  />
  <body>
    <Header />
    <main>
      <article>
        <div class="hero-image">
          {heroImage && <Image width={1020} height={510} src={heroImage} alt="" />}
        </div>
        <div class="post-container">
          {headings.length > 0 && (
            <aside class="toc-sidebar">
              <TableOfContents headings={headings} />
            </aside>
          )}
          <div class="prose">
            <div class="title">
              <div class="date">
                <FormattedDate date={pubDate} />
                {updatedDate && (
                  <div class="last-updated-on">
                    Last updated on <FormattedDate date={updatedDate} />
                  </div>
                )}
              </div>
              <h1>{title}</h1>
              <hr />
            </div>
            <slot />
          </div>
        </div>
      </article>
    </main>
    <Footer />
  </body>
</html>

<style>
main {
  width: calc(100% - 2em);
  max-width: 100%;
  margin: 0;
}
.hero-image {
  width: 100%;
}
.hero-image img {
  display: block;
  margin: 0 auto;
  border-radius: 12px;
  box-shadow: var(--box-shadow);
}
.post-container {
  display: grid;
  grid-template-columns: 220px 1fr;
  gap: 2em;
  max-width: 1020px;
  margin: 0 auto;
  padding: 0 1em;
}
.prose {
  max-width: 720px;
  padding: 1em;
  color: rgb(var(--gray-dark));
}
.toc-sidebar {
  display: block;
}
.title {
  margin-bottom: 1em;
  padding: 1em 0;
  text-align: center;
  line-height: 1;
}
.title h1 {
  margin: 0 0 0.5em 0;
}
.date {
  margin-bottom: 0.5em;
  color: rgb(var(--gray));
  font-family: 'Michroma', 'Arial Black', Impact, sans-serif;
  font-weight: 400;
  letter-spacing: 0.01em;
  font-size: 0.9em;
}
.last-updated-on {
  font-style: italic;
}

/* Responsive images in content */
.prose img {
  max-width: 100%;
  height: auto;
  display: block;
  margin: 1.5em auto;
  border-radius: 8px;
  box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
  max-height: 80vh;
  object-fit: contain;
}

/* Mobile responsiveness */
@media (max-width: 720px) {
  .post-container {
    grid-template-columns: 1fr;
  }
  .toc-sidebar {
    display: none;
  }
  .prose {
    width: 100%;
  }
}
</style>
